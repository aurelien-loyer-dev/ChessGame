# High-strength AI API for React app
# If empty, the app uses relative endpoint /api/ai-move (via Vite proxy in dev).
VITE_AI_API_BASE_URL=

# Endpoint path on the AI server. Can also be a full URL.
VITE_AI_API_MOVE_PATH=/api/ai-move

# Optional API key sent in x-api-key header.
VITE_AI_API_KEY=

# Network timeout in ms for each AI request.
VITE_AI_API_TIMEOUT_MS=15000

# Force server AI for all levels when true.
VITE_AI_FORCE_SERVER=false
